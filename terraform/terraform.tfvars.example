# AWS Configuration
aws_region  = "us-east-2"
environment = "dev"

# Project Configuration
project_name = "greennode-task-engine"

# Network Configuration
vpc_cidr           = "10.0.0.0/16"
public_subnet_cidr = "10.0.1.0/24"

# EC2 Instance Configuration
infrastructure_instance_type = "t3.xlarge"  # 4 vCPU, 16 GB RAM
loadtest_instance_type       = "t3.medium" # 2 vCPU, 4 GB RAM

# SSH Key Pair
# REQUIRED: Create an EC2 key pair in AWS Console first, then specify its name here
key_pair_name = "your-key-pair-name"

# Security Configuration
# IMPORTANT: Restrict this to your IP address for production deployments!
# Example: ["123.456.789.0/32"]
allowed_ssh_cidr = ["0.0.0.0/0"]
